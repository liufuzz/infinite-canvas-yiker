NEXT_PUBLIC_DOC_URL=https://docs.canvas.best

# 后台配置管理员密码。生产环境请改成强密码。
INFINITE_CANVAS_ADMIN_PASSWORD=change-me

# 后台登录 Cookie 签名密钥。生产环境请生成随机长字符串。
# 生成示例：openssl rand -base64 48
INFINITE_CANVAS_ADMIN_SECRET=change-me-random-secret

# Docker Compose 默认会把配置与日志写到 /data/infinite-canvas，并挂载到宿主机 ./data。
INFINITE_CANVAS_CONFIG_FILE=/data/infinite-canvas/config.json
INFINITE_CANVAS_LOG_FILE=/data/infinite-canvas/ai-call-logs.json
